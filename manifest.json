{
  "manifest_version": 3,
  "name": "VoidTube",
  "version": "1.5",
  "description": "The minimalist's choice for a distraction-free YouTube experience.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoidTube"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "1024": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "voidtube@antigravity.ai",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}